{
  "name": "playwright-interactive",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.mjs'",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@playwright/test": "^1.52.0",
    "glob": "^11.0.0",
    "tsx": "^4.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.27.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0"
  }
}
